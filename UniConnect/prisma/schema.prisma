// ─── HMIS Models ─────────────────────────────────────────────

model Institute {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  logo            String?
  address         String?
  city            String
  province        String
  phone           String?
  email           String?
  website         String?
  establishedYear Int?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users            User[]
  academicSessions AcademicSession[]
  departments      HmisDepartment[]
  employees        Employee[]
  studentProfiles  StudentProfile[]
  programs         HmisProgram[]
  subjects         Subject[]
  semesters        Semester[]
  classSections    ClassSection[]
  exams            Exam[]
  feeStructures    FeeStructure[]
  challans         Challan[]
  fine             Fine[]
  discounts        Discount[]
  noticeBoards     NoticeBoard[]

  @@index([slug])
  @@index([city])
  @@index([province])
}

model AcademicSession {
  id          String   @id @default(cuid())
  instituteId String
  name        String
  startDate   DateTime
  endDate     DateTime
  isCurrent   Boolean  @default(false)
  createdAt   DateTime @default(now())

  institute Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  semesters Semester[]

  @@index([instituteId])
  @@index([isCurrent])
}

model HmisDepartment {
  id          String   @id @default(cuid())
  instituteId String
  name        String
  slug        String
  description String?
  headId      String?   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  institute Institute              @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  head      Employee?              @relation("DepartmentHead", fields: [headId], references: [id])
  programs  HmisProgram[]
  employees Employee[]             @relation("EmployeeDepartment")

  @@unique([instituteId, slug])
  @@index([instituteId])
  @@index([headId])
}

model HmisProgram {
  id              String   @id @default(cuid())
  instituteId     String
  departmentId    String?
  name            String
  slug            String
  degreeLevel     DegreeLevel @default(BS)
  duration        Int?
  description     String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  institute      Institute        @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  department     HmisDepartment?  @relation(fields: [departmentId], references: [id])
  subjects       Subject[]
  semesters      Semester[]
  classSections  ClassSection[]
  studentProfiles StudentProfile[]
  feeStructures  FeeStructure[]

  @@unique([instituteId, slug])
  @@index([instituteId])
  @@index([departmentId])
  @@index([degreeLevel])
}

model Subject {
  id             String   @id @default(cuid())
  instituteId    String
  programId      String?
  code           String
  name           String
  creditHours    Int      @default(3)
  isTheory       Boolean  @default(true)
  isLab          Boolean  @default(false)
  description    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  institute        Institute               @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  program          HmisProgram?            @relation(fields: [programId], references: [id])
  prerequisites    SubjectPrerequisite[]   @relation("SubjectPrerequisite")
  requiredFor      SubjectPrerequisite[]   @relation("SubjectRequiredFor")
  classSubjects    ClassSubject[]
  lessonPlans      LessonPlan[]
  timetableEntries TimetableEntry[]
  studentAttendance StudentAttendance[]
  exams            Exam[]

  @@unique([instituteId, code])
  @@index([instituteId])
  @@index([programId])
}

model SubjectPrerequisite {
  subjectId    String
  prerequisiteId String

  subject       Subject @relation("SubjectPrerequisite", fields: [subjectId], references: [id], onDelete: Cascade)
  prerequisite  Subject @relation("SubjectRequiredFor", fields: [prerequisiteId], references: [id], onDelete: Restrict)

  @@id([subjectId, prerequisiteId])
}

model Semester {
  id                String   @id @default(cuid())
  instituteId       String
  academicSessionId String
  programId         String?
  name              String
  semesterNumber    Int?
  startDate         DateTime?
  endDate           DateTime?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  institute       Institute        @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  academicSession AcademicSession  @relation(fields: [academicSessionId], references: [id])
  program         HmisProgram?     @relation(fields: [programId], references: [id])
  classSections   ClassSection[]
  exams           Exam[]
  feeStructures   FeeStructure[]
  academicRecords AcademicRecord[]
  enrollments     Enrollment[]
  challans        Challan[]

  @@index([instituteId])
  @@index([academicSessionId])
  @@index([programId])
}

model ClassSection {
  id              String   @id @default(cuid())
  instituteId     String
  programId       String
  semesterId      String
  name            String
  section         String?
  capacity        Int?
  roomNumber      String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  institute      Institute       @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  program        HmisProgram     @relation(fields: [programId], references: [id])
  semester       Semester        @relation(fields: [semesterId], references: [id])
  classSubjects      ClassSubject[]
  timetableEntries   TimetableEntry[]
  enrollments        Enrollment[]
  lessonPlans        LessonPlan[]
  students           StudentProfile[]
  studentAttendance  StudentAttendance[]

  @@index([instituteId])
  @@index([programId])
  @@index([semesterId])
}

model ClassSubject {
  id              String   @id @default(cuid())
  classSectionId  String
  subjectId       String
  teacherId       String?
  dayOfWeek       DayOfWeek?
  startTime       String?
  endTime         String?
  room            String?
  isActive        Boolean  @default(true)

  classSection ClassSection @relation(fields: [classSectionId], references: [id], onDelete: Cascade)
  subject      Subject      @relation(fields: [subjectId], references: [id])
  teacher      Employee?    @relation(fields: [teacherId], references: [id])

  @@unique([classSectionId, subjectId])
  @@index([classSectionId])
  @@index([subjectId])
  @@index([teacherId])
}

model TimetableEntry {
  id              String   @id @default(cuid())
  classSectionId  String
  subjectId       String
  teacherId       String?
  dayOfWeek       DayOfWeek
  startTime       String
  endTime         String
  room            String?

  classSection ClassSection @relation(fields: [classSectionId], references: [id], onDelete: Cascade)
  subject      Subject      @relation(fields: [subjectId], references: [id])
  teacher      Employee?    @relation(fields: [teacherId], references: [id])

  @@index([classSectionId])
  @@index([subjectId])
  @@index([teacherId])
  @@index([dayOfWeek])
}

model LessonPlan {
  id             String   @id @default(cuid())
  classSectionId String
  subjectId      String
  topic          String
  description    String?
  weekNumber     Int?
  lessonDate     DateTime?
  isCompleted    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  classSection ClassSection @relation(fields: [classSectionId], references: [id], onDelete: Cascade)
  subject      Subject      @relation(fields: [subjectId], references: [id])

  @@index([classSectionId])
  @@index([subjectId])
}

model Employee {
  id             String       @id @default(cuid())
  userId         String       @unique
  instituteId    String
  employeeId     String
  departmentId   String?
  designation    String
  type           EmployeeType @default(TEACHING)
  qualification  String?
  experience     Int?
  salary         Float?
  joinDate       DateTime?
  emergencyContact String?
  address        String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user               User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  institute          Institute              @relation(fields: [instituteId], references: [id])
  department         HmisDepartment?        @relation("EmployeeDepartment", fields: [departmentId], references: [id])
  headOfDepartment   HmisDepartment?        @relation("DepartmentHead")
  attendanceRecords  EmployeeAttendance[]
  leaveRequests      LeaveRequest[]
  payrolls           Payroll[]
  evaluations        PerformanceEvaluation[]
  taughtSubjects     ClassSubject[]
  timetableEntries   TimetableEntry[]
  exams              Exam[]
  documents          EmployeeDocument[]
  leaveApprovals     LeaveRequest[]          @relation("LeaveApprover")
  evaluationsGiven   PerformanceEvaluation[] @relation("Evaluator")
  markedAttendance   StudentAttendance[]
  gradedMarks        MarksEntry[]
  receivedPayments   FeePayment[]
  approvedDiscounts  Discount[]
  createdNotices     NoticeBoard[]

  @@unique([instituteId, employeeId])
  @@index([instituteId])
  @@index([departmentId])
  @@index([type])
}

model EmployeeDocument {
  id          String @id @default(cuid())
  employeeId  String
  name        String
  fileUrl     String
  type        String?
  uploadedAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model EmployeeAttendance {
  id         String   @id @default(cuid())
  employeeId String
  date       DateTime
  checkIn    DateTime?
  checkOut   DateTime?
  status     AttendanceStatus @default(PRESENT)
  overtime   Float?
  remarks    String?

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
  @@index([status])
}

model LeaveRequest {
  id          String     @id @default(cuid())
  employeeId  String
  type        LeaveType
  startDate   DateTime
  endDate     DateTime
  reason      String
  status      LeaveStatus @default(PENDING)
  approvedById String?
  remarks     String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  approvedBy Employee? @relation("LeaveApprover", fields: [approvedById], references: [id])

  @@index([employeeId])
  @@index([status])
  @@index([approvedById])
}

model Payroll {
  id          String   @id @default(cuid())
  employeeId  String
  month       Int
  year        Int
  basicSalary Float
  allowances  Float    @default(0)
  deductions  Float    @default(0)
  netSalary   Float
  paymentDate DateTime?
  status      String   @default("PENDING")
  remarks     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, month, year])
  @@index([employeeId])
  @@index([status])
}

model PerformanceEvaluation {
  id           String   @id @default(cuid())
  employeeId   String
  evaluatorId  String?
  period       String
  rating       Float?
  feedback     String?
  goals        String?
  evaluatedAt  DateTime @default(now())
  createdAt    DateTime @default(now())

  employee  Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  evaluator Employee? @relation("Evaluator", fields: [evaluatorId], references: [id])

  @@index([employeeId])
  @@index([evaluatorId])
}

model StudentProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  instituteId     String
  rollNumber      String
  programId       String
  classSectionId  String?
  admissionDate   DateTime?
  semester        Int?
  fatherName      String?
  fatherPhone     String?
  motherName      String?
  motherPhone     String?
  guardianName    String?
  guardianPhone   String?
  address         String?
  dateOfBirth     DateTime?
  bloodGroup      String?
  transportRequired Boolean? @default(false)
  hostelRequired    Boolean? @default(false)
